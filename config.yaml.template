# CLIProxyAPI — BidDeed.AI Gateway Config
# THREE-TIER ROUTER: Gemini (free) → DeepSeek (cheap) → Claude (quality)
# Gemini FREE tier RESTORED with paid key (Mar 25 2026)
# Updated: 2026-03-25

host: "127.0.0.1"
port: 8317

tls:
  enable: false

remote-management:
  allow-remote: false
  secret-key: "MGMT_SECRET_PLACEHOLDER"
  disable-control-panel: true

auth-dir: "/data/auth"

api-keys:
  - "GATEWAY_KEY_PLACEHOLDER"

debug: false
logging-to-file: true
logs-max-total-size-mb: 100
error-logs-max-files: 5

pprof:
  enable: false

commercial-mode: true
request-retry: 3
max-retry-credentials: 3
max-retry-interval: 15

routing:
  strategy: "round-robin"

quota-exceeded:
  switch-project: true
  switch-preview-model: true

# ============================================
# TIER 0: GEMINI (FREE — bulk pipeline traffic)
# Paid key, generous free tier
# Priority: route here FIRST to minimize cost
# Restored: 2026-03-25
# ============================================
google-gemini:
  - api-key: "GEMINI_KEY_PLACEHOLDER"
    models:
      - name: "gemini-2.0-flash"
        alias: "gemini-flash"
      - name: "gemini-2.5-flash-preview-04-17"
        alias: "gemini-flash-preview"

# ============================================
# TIER 1: DEEPSEEK (CHEAP — bulk parsing fallback)
# $0.28/1M input, $1.12/1M output
# Handles: overflow from Gemini, structured parsing
# ============================================
openai-compatibility:
  - name: "deepseek"
    base-url: "https://api.deepseek.com/v1"
    api-key-entries:
      - api-key: "DEEPSEEK_KEY_PLACEHOLDER"
    models:
      - name: "deepseek-chat"
        alias: "deepseek-v3"
      - name: "deepseek-reasoner"
        alias: "deepseek-r1"

# ============================================
# TIER 2: CLAUDE API (ESCALATION — complex reasoning)
# $3/$15 per 1M (Sonnet), $5/$25 (Opus)
# Handles: lien priority, legal edge cases, max bid
# ============================================
claude-api-key:
  - api-key: "ANTHROPIC_KEY_PLACEHOLDER"
    models:
      - name: "claude-sonnet-4-20250514"
        alias: "claude-sonnet"
      - name: "claude-haiku-4-5-20251001"
        alias: "claude-haiku"

# ============================================
# SMART ROUTER PRIORITY (Mar 25 2026):
# Gemini Free → DeepSeek Cheap → Claude Quality
# ============================================

payload:
  default:
    - models:
        - name: "gemini-2.0-flash"
      params:
        temperature: 0.3
    - models:
        - name: "deepseek-chat"
      params:
        temperature: 0.3
    - models:
        - name: "deepseek-reasoner"
      params:
        temperature: 0.1
