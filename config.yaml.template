# CLIProxyAPI — BidDeed.AI Gateway Config
# TWO-TIER ROUTER: DeepSeek (primary) + Claude (escalation)
# Gemini FREE tier ELIMINATED — no more key expiry
# Updated: 2026-03-19

host: "127.0.0.1"
port: 8317

tls:
  enable: false

remote-management:
  allow-remote: false
  secret-key: "MGMT_SECRET_PLACEHOLDER"
  disable-control-panel: true

auth-dir: "/data/auth"

api-keys:
  - "GATEWAY_KEY_PLACEHOLDER"

debug: false
logging-to-file: true
logs-max-total-size-mb: 100
error-logs-max-files: 5

pprof:
  enable: false

commercial-mode: true
request-retry: 3
max-retry-credentials: 3
max-retry-interval: 15

routing:
  strategy: "round-robin"

quota-exceeded:
  switch-project: true
  switch-preview-model: true

# ============================================
# TIER 1: DEEPSEEK (PRIMARY — all pipeline traffic)
# $0.28/1M input, $1.12/1M output
# Handles: 80-90% of all work
# ============================================
openai-compatibility:
  - name: "deepseek"
    base-url: "https://api.deepseek.com/v1"
    api-key-entries:
      - api-key: "DEEPSEEK_KEY_PLACEHOLDER"
    models:
      - name: "deepseek-chat"
        alias: "deepseek-v3"
      - name: "deepseek-reasoner"
        alias: "deepseek-r1"

# ============================================
# TIER 2: CLAUDE API (ESCALATION — complex reasoning)
# $3/$15 per 1M (Sonnet), $5/$25 (Opus)
# Handles: lien priority, legal edge cases, max bid
# ============================================
claude-api-key:
  - api-key: "ANTHROPIC_KEY_PLACEHOLDER"
    models:
      - name: "claude-sonnet-4-20250514"
        alias: "claude-sonnet"
      - name: "claude-haiku-4-5-20251001"
        alias: "claude-haiku"

# ============================================
# GEMINI: REMOVED (2026-03-19)
# All 3 keys = same expired key. Unreliable.
# DeepSeek at $0.28/1M replaces FREE tier.
# ============================================

payload:
  default:
    - models:
        - name: "deepseek-chat"
      params:
        temperature: 0.3
    - models:
        - name: "deepseek-reasoner"
      params:
        temperature: 0.1
